  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "node --require ./scripts/node-polyfills.js ./node_modules/eslint/bin/eslint.js .",
    "lintfix": "node --require ./scripts/node-polyfills.js ./node_modules/eslint/bin/eslint.js . --fix",
    "format:check": "prettier . --check",
    "format": "prettier --write --list-different .",
    "typecheck": "tsc --noEmit",
    "test": "node --require ./scripts/node-polyfills.js ./node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --require ./scripts/node-polyfills.js ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --require ./scripts/node-polyfills.js ./node_modules/jest/bin/jest.js --coverage --runInBand"
  },
