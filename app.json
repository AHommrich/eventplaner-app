{
  "expo": {
    "name": "eveplan",
    "slug": "eveplan",
    "scheme": "eventplaner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F07070"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["comgooglemaps"],
        "NSCameraUsageDescription": "eveplan liest deinen Einladungs-QR-Code und erlaubt dir, Fotos für das Hochzeitsalbum aufzunehmen.",
        "NSPhotoLibraryUsageDescription": "eveplan lädt Fotos aus deiner Bibliothek in das Hochzeitsalbum hoch, wenn du das möchtest.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.ahommrichsorganization.eveplan"
    },
    "android": {
      "package": "com.ahommrichsorganization.eveplan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-font",
      "@sentry/react-native/expo",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPodfileProperties": {
              "SWIFT_STRICT_CONCURRENCY": "minimal",
              "OTHER_SWIFT_FLAGS": "$(inherited) -strict-concurrency=minimal"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "69c16c3f-227c-49b9-adcf-4f0bd57eaf29"
      }
    },
    "owner": "ahommrichs-organization"
  }
}
